{
  "name": "moneypit-mod-installer",
  "version": "1.0.0",
  "description": "MoneyPit Mod Installer — Easy BeamNG.drive mod installation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": ["beamng", "mod", "installer", "moneypit", "racing"],
  "author": "MoneyPit",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.2.0"
  },
  "build": {
    "appId": "com.moneypit.modinstaller",
    "productName": "MoneyPit Mod Installer",
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "splash.html",
      "styles.css",
      "renderer.js",
      "racer.js"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MoneyPit Mod Installer"
    },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
